# Frontend Dockerfile - Build and serve Vite app in production
FROM node:20-slim AS builder

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@latest

# Copy package files
COPY package.json pnpm-workspace.yaml ./
COPY tsconfig.base.json ./
COPY lib/ ./lib/
COPY artifacts/andaralab/ ./artifacts/andaralab/

WORKDIR /app/artifacts/andaralab

# Install dependencies
# @tanstack/query-test-utils is not on npm — create a local stub and use pnpm overrides
RUN mkdir -p /app/stub/@tanstack/query-test-utils && \
    printf '{"name":"@tanstack/query-test-utils","version":"0.0.0","main":"index.js"}' \
      > /app/stub/@tanstack/query-test-utils/package.json && \
    printf '// stub' > /app/stub/@tanstack/query-test-utils/index.js && \
    node -e " \
      const fs=require('fs'); \
      const p=JSON.parse(fs.readFileSync('package.json','utf8')); \
      p.pnpm=p.pnpm||{}; \
      p.pnpm.overrides=p.pnpm.overrides||{}; \
      p.pnpm.overrides['@tanstack/query-test-utils']='file:/app/stub/@tanstack/query-test-utils'; \
      fs.writeFileSync('package.json',JSON.stringify(p,null,2)); \
    " && \
    pnpm install --no-frozen-lockfile

# Set API base URL for production
RUN echo 'VITE_API_BASE_URL=/api' > .env.production

# Build the frontend
RUN pnpm run build

# Production stage - serve with nginx
FROM nginx:alpine

# Remove any default/cached favicons from old projects
RUN rm -f /usr/share/nginx/html/favicon.ico         /usr/share/nginx/html/apple-touch-icon.png         /usr/share/nginx/html/apple-touch-icon-precomposed.png

# Copy built files from builder
COPY --from=builder /app/artifacts/andaralab/dist/public /usr/share/nginx/html

# Also copy public folder (gambar.png, etc.) - in case dist didn't include it
COPY --from=builder /app/artifacts/andaralab/public/ /usr/share/nginx/html/

# Copy nginx configuration
COPY <<EOF /etc/nginx/conf.d/default.conf
server {
    listen 80;
    server_name localhost;
    root /usr/share/nginx/html;
    index index.html;

    # Disable caching for HTML files to force refresh
    location ~* \.html$ {
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
        expires off;
    }

    # SPA routing
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API proxy - route to backend container via Docker service name
    location /api/ {
        resolver 127.0.0.11 valid=30s ipv6=off;
        proxy_pass http://backend:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host \$host;
        proxy_cache_bypass \$http_upgrade;
    }

    # Cache static assets with hash in filename (JS, CSS)
    location ~* \.(js|css)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # NO CACHE for favicons and manifests - always fetch fresh
    location ~* \.(ico|svg|json|png)$ {
        if (\ ~* (favicon|manifest|apple-touch)) {
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0";
            expires off;
        }
    }
}
EOF

EXPOSE 80

# Wait for backend to be resolvable before starting nginx
RUN cat > /wait-for-backend.sh << 'EOF'
#!/bin/sh
echo "Waiting for backend DNS..."
until nslookup backend > /dev/null 2>&1; do
  echo "  backend not ready, retrying in 2s..."
  sleep 2
done
echo "Backend DNS resolved, starting nginx..."
exec "$@"
EOF
RUN chmod +x /wait-for-backend.sh

CMD ["/wait-for-backend.sh", "nginx", "-g", "daemon off;"]
